rules_version = '2';

// Role model:
//   Visitor  — request.auth == null
//   Player   — request.auth != null
//   DM/admin — users/{uid}.role == 'dm'  (set in Firestore profile)
//
// Write access requires only authentication — the app controls which
// UI is shown based on DM mode. Read access enforces hidden/visible.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isDM() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'dm';
    }

    // ── user profiles ─────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // ── timeline ──────────────────────────────────────────────────────────────
    match /campaigns/{campaignId}/timeline/{entryId} {
      allow read:   if isDM() || resource.data.hidden != true;
      allow write:  if isSignedIn();
    }

    // ── locations ─────────────────────────────────────────────────────────────
    match /campaigns/{campaignId}/locations/{locationId} {
      allow read:   if isDM() || resource.data.visibility != 'hidden';
      allow write:  if isSignedIn();
    }

    // ── characters ────────────────────────────────────────────────────────────
    match /campaigns/{campaignId}/characters/{characterId} {
      allow read:   if isDM() || resource.data.visibility != 'hidden';
      // DMs manage NPCs; players can only write their own character (docId == uid)
      allow write:  if isDM() || (isSignedIn() && characterId == request.auth.uid);
    }

    // ── quests ────────────────────────────────────────────────────────────────
    match /campaigns/{campaignId}/quests/{questId} {
      allow read:   if isDM() || resource.data.visibility != 'hidden';
      allow write:  if isSignedIn();
    }

    // ── notes ─────────────────────────────────────────────────────────────────
    match /campaigns/{campaignId}/notes/{noteId} {
      // Guests read pub only; players also read their own priv; DMs read everything
      allow read:   if resource.data.scope == 'pub'
                    || (isSignedIn() && resource.data.scope == 'priv')
                    || isDM();
      allow create: if isSignedIn();
      // Only the author or a DM can edit/delete
      allow update, delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isDM());
    }

    // ── loot items ────────────────────────────────────────────────────────────
    match /campaigns/{campaignId}/loot/{itemId} {
      allow get:    if isDM() || resource.data.recordVisibility == 'public';
      allow list:   if isDM() || isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isDM() || isSignedIn();
    }

    // ── DM-only loot secrets ──────────────────────────────────────────────────
    match /campaigns/{campaignId}/lootDm/{itemId} {
      allow read, write: if isDM();
    }

    // ── presence ──────────────────────────────────────────────────────────────
    match /campaigns/{campaignId}/presence/{userId} {
      allow read:   if isSignedIn();
      allow write:  if isSignedIn() && request.auth.uid == userId;
    }
  }
}
